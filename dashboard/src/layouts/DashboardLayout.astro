---
import Sidebar from '@components/sidebar/Sidebar.astro';
import layoutStyles from '@styles/layout.module.css';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Icefall</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('icefall-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    {/* a11y [WCAG 2.4.1]: skip link to bypass sidebar navigation */}
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class={layoutStyles.layout}>
      <Sidebar />
      <main id="main-content" tabindex="-1" class={layoutStyles.main}>
        <div class={layoutStyles.content}>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
