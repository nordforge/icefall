---
// View Transitions disabled — caused intermittent CSS module loading failures
import Sidebar from "@components/sidebar/Sidebar.astro";
import CommandPalette from "@islands/shared/CommandPalette/CommandPalette";
import KeyboardShortcuts from "@islands/shared/KeyboardShortcuts/KeyboardShortcuts";
import Toast from "@islands/shared/Toast/Toast";
import ReconnectOverlay from "@islands/update/ReconnectOverlay/ReconnectOverlay";
import OfflineServerBanner from "@islands/shared/OfflineServerBanner/OfflineServerBanner";
import sidebarStyles from "@styles/sidebar.module.css";
import layoutStyles from "@styles/layout.module.css";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Icefall</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@100..800&display=swap"
    />
    <!-- ClientRouter (View Transitions) disabled — causes intermittent CSS module loading failures on navigation -->
    <script is:inline>
      var s = localStorage.getItem("icefall-theme");
      document.documentElement.setAttribute(
        "data-theme",
        s ||
          (matchMedia("(prefers-color-scheme:dark)").matches
            ? "dark"
            : "light"),
      );
    </script>
    <script src="../scripts/auth-guard.ts"></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <CommandPalette client:only="preact" />
    <div class={`ice-layout ${layoutStyles.layout}`}>
      <button
        type="button"
        class={sidebarStyles.hamburger}
        id="sidebar-toggle"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="sidebar-panel"
      >
        <svg
          aria-hidden="true"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div
        class={sidebarStyles.backdrop}
        id="sidebar-backdrop"
        aria-hidden="true"
      >
      </div>
      <div id="sidebar-panel">
        <Sidebar />
      </div>
      <OfflineServerBanner client:only="preact" />
      <main
        id="main-content"
        tabindex="-1"
        class={`ice-main ${layoutStyles.main}`}
      >
        <div class={layoutStyles.content}>
          <slot />
        </div>
      </main>
    </div>
    <KeyboardShortcuts client:idle />
    <Toast client:only="preact" />
    <ReconnectOverlay client:only="preact" />
    <script src="../scripts/mobile-drawer.ts"></script>
  </body>
</html>
