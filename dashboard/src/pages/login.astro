---
import OnboardingLayout from '@/layouts/OnboardingLayout.astro';
---

<OnboardingLayout title="Login" step={0}>
  <div id="login-form" style="max-width: 400px; margin: 0 auto;">
    <h2 style="margin-bottom: 1rem;">Sign in to Icefall</h2>
    <div id="error" role="alert" style="display:none; color: var(--color-error); margin-bottom: 1rem; font-size: 0.875rem;"></div>

    <!-- Step 1: Email + Password -->
    <div id="credentials-step" style="display: flex; flex-direction: column; gap: 1rem;">
      <div>
        <label for="email" style="display: block; font-size: 0.8125rem; font-weight: 500; margin-bottom: 4px;">Email</label>
        <input id="email" type="email" autocomplete="email" style="width: 100%; height: 36px; padding: 0 12px; border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-surface); color: var(--color-text); font-family: inherit; font-size: 0.875rem;" />
      </div>
      <div>
        <label for="password" style="display: block; font-size: 0.8125rem; font-weight: 500; margin-bottom: 4px;">Password</label>
        <input id="password" type="password" autocomplete="current-password" style="width: 100%; height: 36px; padding: 0 12px; border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-surface); color: var(--color-text); font-family: inherit; font-size: 0.875rem;" />
      </div>
      <button id="submit" type="button" style="height: 36px; background: var(--color-primary); color: white; border: none; border-radius: 4px; font-weight: 500; cursor: pointer; font-family: inherit;">Sign in</button>

      <!-- OAuth SSO buttons -->
      <div id="oauth-section" style="display: none;">
        <div style="display: flex; align-items: center; gap: 12px; margin-top: 0.25rem;">
          <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
          <span style="font-size: 0.75rem; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">or</span>
          <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
        </div>

        <!-- a11y [1.1.1]: SVG icons are decorative, using aria-hidden -->
        <a id="oauth-github" href="/api/v1/auth/oauth/github/authorize" style="display: none; align-items: center; justify-content: center; gap: 8px; height: 36px; background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: 4px; font-weight: 500; cursor: pointer; font-family: inherit; font-size: 0.875rem; text-decoration: none; transition: border-color 0.15s ease;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          Sign in with GitHub
        </a>

        <a id="oauth-google" href="/api/v1/auth/oauth/google/authorize" style="display: none; align-items: center; justify-content: center; gap: 8px; height: 36px; background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: 4px; font-weight: 500; cursor: pointer; font-family: inherit; font-size: 0.875rem; text-decoration: none; margin-top: 0.5rem; transition: border-color 0.15s ease;">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Sign in with Google
        </a>
      </div>
    </div>

    <!-- Step 2: 2FA Code (hidden by default) -->
    <!-- a11y [1.3.1]: form fields have associated labels -->
    <div id="totp-step" style="display: none; flex-direction: column; gap: 1rem;">
      <p style="font-size: 0.875rem; color: var(--color-text-secondary);">
        Enter the 6-digit code from your authenticator app, or an 8-character backup code.
      </p>
      <div>
        <label for="totp-code" style="display: block; font-size: 0.8125rem; font-weight: 500; margin-bottom: 4px;">Authentication code</label>
        <input
          id="totp-code"
          type="text"
          inputmode="numeric"
          autocomplete="one-time-code"
          maxlength="8"
          placeholder="000000"
          style="width: 100%; height: 36px; padding: 0 12px; border: 1px solid var(--color-border); border-radius: 4px; background: var(--color-surface); color: var(--color-text); font-family: var(--font-mono, monospace); font-size: 1.125rem; letter-spacing: 0.15em; text-align: center;"
        />
      </div>
      <button id="totp-submit" type="button" style="height: 36px; background: var(--color-primary); color: white; border: none; border-radius: 4px; font-weight: 500; cursor: pointer; font-family: inherit;">Verify</button>
      <button id="totp-back" type="button" style="height: 36px; background: transparent; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: 4px; font-weight: 500; cursor: pointer; font-family: inherit;">Back to login</button>
    </div>
  </div>

  <script is:inline>
    let pendingUserId = null;

    // Check for OAuth error in URL
    const urlParams = new URLSearchParams(window.location.search);
    const oauthError = urlParams.get('error');
    if (oauthError) {
      const errEl = document.getElementById('error');
      if (oauthError === 'oauth_denied') {
        errEl.textContent = 'OAuth authorization was denied or cancelled.';
      } else if (oauthError === 'oauth_failed') {
        errEl.textContent = 'OAuth login failed. Please try again or use email/password.';
      } else {
        errEl.textContent = 'Login error. Please try again.';
      }
      errEl.style.display = 'block';
      // Clean the URL
      window.history.replaceState({}, '', '/login');
    }

    // Fetch enabled OAuth providers and show buttons
    fetch('/api/v1/settings/oauth/providers', { credentials: 'same-origin' })
      .then(r => r.json())
      .then(d => {
        const providers = d.data || {};
        let anyEnabled = false;
        if (providers.github) {
          document.getElementById('oauth-github').style.display = 'flex';
          anyEnabled = true;
        }
        if (providers.google) {
          document.getElementById('oauth-google').style.display = 'flex';
          anyEnabled = true;
        }
        if (anyEnabled) {
          document.getElementById('oauth-section').style.display = 'block';
        }
      })
      .catch(() => {});

    document.getElementById('submit').addEventListener('click', async () => {
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const errEl = document.getElementById('error');
      errEl.style.display = 'none';

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Login failed';
          errEl.style.display = 'block';
          return;
        }

        // Check if 2FA is required
        if (data.requires_2fa && data.user_id) {
          pendingUserId = data.user_id;
          document.getElementById('credentials-step').style.display = 'none';
          document.getElementById('totp-step').style.display = 'flex';
          document.getElementById('totp-code').focus();
          return;
        }

        window.location.href = '/';
      } catch {
        errEl.textContent = 'Connection failed';
        errEl.style.display = 'block';
      }
    });

    document.getElementById('totp-submit').addEventListener('click', async () => {
      const code = document.getElementById('totp-code').value.trim();
      const errEl = document.getElementById('error');
      errEl.style.display = 'none';

      if (!code) {
        errEl.textContent = 'Please enter your authentication code';
        errEl.style.display = 'block';
        return;
      }

      try {
        const res = await fetch('/api/v1/auth/2fa/validate', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: pendingUserId, code }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Invalid code';
          errEl.style.display = 'block';
          return;
        }
        window.location.href = '/';
      } catch {
        errEl.textContent = 'Connection failed';
        errEl.style.display = 'block';
      }
    });

    document.getElementById('totp-back').addEventListener('click', () => {
      pendingUserId = null;
      document.getElementById('totp-step').style.display = 'none';
      document.getElementById('credentials-step').style.display = 'flex';
      document.getElementById('totp-code').value = '';
      document.getElementById('error').style.display = 'none';
    });

    document.getElementById('password').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('submit').click();
    });

    document.getElementById('totp-code').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('totp-submit').click();
    });
  </script>
</OnboardingLayout>
