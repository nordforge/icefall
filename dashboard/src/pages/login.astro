---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in | Icefall</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@100..800&display=swap" />
    <style is:inline>
      html { box-sizing: border-box; }
      *, *::before, *::after { box-sizing: inherit; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-bg);
        color: var(--color-text);
      }
      .login-wrapper {
        width: 100%;
        max-width: 400px;
        padding: var(--space-6);
      }
      .login-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-8);
      }
      .login-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        margin-bottom: var(--space-6);
        font-size: var(--text-xl);
        font-weight: var(--weight-semibold);
        color: var(--color-text);
        text-decoration: none;
      }
      .login-logo svg {
        color: var(--color-primary);
      }
      .login-title {
        font-size: var(--text-lg);
        font-weight: var(--weight-semibold);
        text-align: center;
        margin-bottom: var(--space-1);
      }
      .login-subtitle {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        text-align: center;
        margin-bottom: var(--space-6);
      }
      .login-error {
        display: none;
        background: oklch(0.95 0.04 25);
        border: 1px solid oklch(0.85 0.08 25);
        color: oklch(0.4 0.15 25);
        border-radius: var(--radius-sm);
        padding: var(--space-3);
        font-size: var(--text-sm);
        margin-bottom: var(--space-4);
      }
      :global([data-theme="dark"]) .login-error {
        background: oklch(0.2 0.04 25);
        border-color: oklch(0.35 0.08 25);
        color: oklch(0.8 0.08 25);
      }
      .login-fields {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }
      .login-field label {
        display: block;
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        margin-bottom: var(--space-1);
      }
      .login-field input {
        width: 100%;
        height: var(--input-height, 40px);
        padding: 0 var(--space-3);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        background: var(--color-surface);
        color: var(--color-text);
        font-family: inherit;
        font-size: var(--text-sm);
        transition: border-color 0.15s ease;
      }
      .login-field input:focus {
        outline: 2px solid var(--color-border-focus);
        outline-offset: -1px;
        border-color: var(--color-border-focus);
      }
      .login-btn-primary {
        width: 100%;
        height: var(--input-height, 40px);
        background: var(--color-primary);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-weight: var(--weight-medium);
        font-size: var(--text-sm);
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.15s ease;
      }
      .login-btn-primary:hover { opacity: 0.9; }
      .login-btn-primary:focus-visible {
        outline: 2px solid var(--color-border-focus);
        outline-offset: 2px;
      }
      .login-btn-secondary {
        width: 100%;
        height: var(--input-height, 40px);
        background: var(--color-surface);
        color: var(--color-text);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        font-weight: var(--weight-medium);
        font-size: var(--text-sm);
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        transition: border-color 0.15s ease;
      }
      .login-btn-secondary:hover { border-color: var(--color-text-muted); }
      .login-btn-secondary:focus-visible {
        outline: 2px solid var(--color-border-focus);
        outline-offset: 2px;
      }
      .login-divider {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin: var(--space-4) 0;
      }
      .login-divider span {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .login-divider::before,
      .login-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--color-border);
      }
      .login-totp-input {
        font-family: var(--font-mono) !important;
        font-size: var(--text-lg) !important;
        letter-spacing: 0.15em;
        text-align: center;
      }
      .login-hint {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        margin-bottom: var(--space-2);
      }
      @media (prefers-reduced-motion: reduce) {
        .login-btn-primary, .login-btn-secondary, .login-field input { transition: none; }
      }
    </style>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('icefall-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <div class="login-wrapper">
      <div class="login-card">
        <a href="/" class="login-logo">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 512 512" fill="none">
            <path d="M161 291L231 426L221 231L131 321Z" fill="currentColor"/>
            <path d="M236 86L326 181L251 426L231 426Z" fill="currentColor"/>
            <path d="M361 321L271 426L306 251L381 296Z" fill="currentColor"/>
          </svg>
          Icefall
        </a>
        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to your account to continue</p>

        <div id="error" class="login-error" role="alert"></div>

        <div id="credentials-step" class="login-fields">
          <div class="login-field">
            <label for="email">Email</label>
            <input id="email" type="email" autocomplete="email" placeholder="you@example.com" />
          </div>
          <div class="login-field">
            <label for="password">Password</label>
            <input id="password" type="password" autocomplete="current-password" />
          </div>
          <button id="submit" type="button" class="login-btn-primary">Sign in</button>

          <div id="oauth-section" style="display: none;">
            <div class="login-divider"><span>or</span></div>
            <a id="oauth-github" href="/api/v1/auth/oauth/github/authorize" class="login-btn-secondary" style="display: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              Sign in with GitHub
            </a>
            <a id="oauth-google" href="/api/v1/auth/oauth/google/authorize" class="login-btn-secondary" style="display: none; margin-top: var(--space-2);">
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
              Sign in with Google
            </a>
          </div>
        </div>

        <div id="totp-step" style="display: none;" class="login-fields">
          <p class="login-hint">
            Enter the 6-digit code from your authenticator app, or an 8-character backup code.
          </p>
          <div class="login-field">
            <label for="totp-code">Authentication code</label>
            <input id="totp-code" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="8" placeholder="000000" class="login-totp-input" />
          </div>
          <button id="totp-submit" type="button" class="login-btn-primary">Verify</button>
          <button id="totp-back" type="button" class="login-btn-secondary">Back to login</button>
        </div>
      </div>
    </div>

  <script is:inline>
    let pendingUserId = null;

    // Redirect to onboarding if setup is incomplete
    fetch('/api/v1/onboarding/status', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(ob) {
        if (!ob.is_complete) window.location.href = '/onboarding';
      })
      .catch(function() {});

    // Check for OAuth error in URL
    const urlParams = new URLSearchParams(window.location.search);
    const oauthError = urlParams.get('error');
    if (oauthError) {
      const errEl = document.getElementById('error');
      if (oauthError === 'oauth_denied') {
        errEl.textContent = 'OAuth authorization was denied or cancelled.';
      } else if (oauthError === 'oauth_failed') {
        errEl.textContent = 'OAuth login failed. Please try again or use email/password.';
      } else {
        errEl.textContent = 'Login error. Please try again.';
      }
      errEl.style.display = 'block';
      // Clean the URL
      window.history.replaceState({}, '', '/login');
    }

    // Fetch enabled OAuth providers and show buttons
    fetch('/api/v1/settings/oauth/providers', { credentials: 'same-origin' })
      .then(r => r.json())
      .then(d => {
        const providers = d.data || {};
        let anyEnabled = false;
        if (providers.github) {
          document.getElementById('oauth-github').style.display = 'flex';
          anyEnabled = true;
        }
        if (providers.google) {
          document.getElementById('oauth-google').style.display = 'flex';
          anyEnabled = true;
        }
        if (anyEnabled) {
          document.getElementById('oauth-section').style.display = 'block';
        }
      })
      .catch(() => {});

    document.getElementById('submit').addEventListener('click', async () => {
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const errEl = document.getElementById('error');
      errEl.style.display = 'none';

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Login failed';
          errEl.style.display = 'block';
          return;
        }

        // Check if 2FA is required
        if (data.requires_2fa && data.user_id) {
          pendingUserId = data.user_id;
          document.getElementById('credentials-step').style.display = 'none';
          document.getElementById('totp-step').style.display = 'flex';
          document.getElementById('totp-code').focus();
          return;
        }

        window.location.href = '/';
      } catch {
        errEl.textContent = 'Connection failed';
        errEl.style.display = 'block';
      }
    });

    document.getElementById('totp-submit').addEventListener('click', async () => {
      const code = document.getElementById('totp-code').value.trim();
      const errEl = document.getElementById('error');
      errEl.style.display = 'none';

      if (!code) {
        errEl.textContent = 'Please enter your authentication code';
        errEl.style.display = 'block';
        return;
      }

      try {
        const res = await fetch('/api/v1/auth/2fa/validate', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: pendingUserId, code }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Invalid code';
          errEl.style.display = 'block';
          return;
        }
        window.location.href = '/';
      } catch {
        errEl.textContent = 'Connection failed';
        errEl.style.display = 'block';
      }
    });

    document.getElementById('totp-back').addEventListener('click', () => {
      pendingUserId = null;
      document.getElementById('totp-step').style.display = 'none';
      document.getElementById('credentials-step').style.display = 'flex';
      document.getElementById('totp-code').value = '';
      document.getElementById('error').style.display = 'none';
    });

    document.getElementById('password').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('submit').click();
    });

    document.getElementById('totp-code').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('totp-submit').click();
    });
  </script>
  </body>
</html>
