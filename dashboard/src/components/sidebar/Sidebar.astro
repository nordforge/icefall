---
import styles from '@styles/sidebar.module.css';
import ThemeToggle from '../theme/ThemeToggle';
import LogoutButton from '@islands/shared/LogoutButton/LogoutButton';
import SystemStatus from '@islands/shared/SystemStatus/SystemStatus';
import UpdatePill from '@islands/update/UpdatePill/UpdatePill';
import UpdateDialog from '@islands/update/UpdateDialog/UpdateDialog';
import TeamSwitcher from '@islands/teams/TeamSwitcher/TeamSwitcher';
import pkg from '../../../package.json';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Apps', icon: 'grid' },
  { href: '/projects', label: 'Projects', icon: 'folder' },
  { href: '/databases', label: 'Databases', icon: 'database' },
  { href: '/services', label: 'Services', icon: 'package' },
  { href: '/servers', label: 'Servers', icon: 'server' },
  { href: '/shared-variables', label: 'Variables', icon: 'key' },
  { href: '/analytics', label: 'Analytics', icon: 'chart' },
  { href: '/incidents', label: 'Incidents', icon: 'alert' },
  { href: '/users', label: 'Users', icon: 'users' },
  { href: '/profile', label: 'Profile', icon: 'profile' },
  { href: '/settings', label: 'Settings', icon: 'settings' },
  { href: '/docs', label: 'Docs', icon: 'book', external: true },
];

function isActive(href: string): boolean {
  if (href === '/') {
    // The root route is the apps listing — also highlight for /apps/* detail pages
    return currentPath === '/' || currentPath.startsWith('/apps');
  }
  return currentPath.startsWith(href);
}
---

<aside class={`ice-sidebar ${styles.sidebar}`}>
  <div class={styles.logoRow}>
    <a href="/" class={styles.logo}>
      <span class={styles.logoIcon}>
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 512 512" fill="none">
          <path d="M161 291L231 426L221 231L131 321Z" fill="currentColor"/>
          <path d="M236 86L326 181L251 426L231 426Z" fill="currentColor"/>
          <path d="M361 321L271 426L306 251L381 296Z" fill="currentColor"/>
        </svg>
      </span>
      <span>
        Icefall
        <span class={styles.subtitle}>v{pkg.version}</span>
      </span>
    </a>
    <SystemStatus client:idle />
  </div>

  <TeamSwitcher client:load />

  {/* a11y [WCAG 2.1.1]: arrow-key navigation via roving tabindex managed by inline script */}
  <nav aria-label="Main" class={styles.nav} id="sidebar-nav">
    {navItems.map((item, i) => (
      <a
        href={item.href}
        aria-current={isActive(item.href) ? 'page' : undefined}
        class:list={[styles.navItem, isActive(item.href) && styles.navItemActive]}
        data-astro-prefetch={item.external ? undefined : "hover"}
        tabindex={i === 0 ? 0 : -1}
        data-nav-index={i}
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener noreferrer' : undefined}
      >
        <svg aria-hidden="true" class={styles.navIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          {item.icon === 'grid' && <><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></>}
          {item.icon === 'folder' && <><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></>}
          {item.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" /></>}
          {item.icon === 'server' && <><rect x="2" y="2" width="20" height="8" rx="2" /><rect x="2" y="14" width="20" height="8" rx="2" /><circle cx="6" cy="6" r="1" fill="currentColor" /><circle cx="6" cy="18" r="1" fill="currentColor" /></>}
          {item.icon === 'users' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></>}
          {item.icon === 'profile' && <><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></>}
          {item.icon === 'settings' && <><path d="M20 7h-9" /><path d="M14 17H5" /><circle cx="17" cy="17" r="3" /><circle cx="7" cy="7" r="3" /></>}
          {item.icon === 'package' && <><path d="M12.89 1.45l8 4A2 2 0 0 1 22 7.24v9.53a2 2 0 0 1-1.11 1.79l-8 4a2 2 0 0 1-1.79 0l-8-4A2 2 0 0 1 2 16.76V7.24a2 2 0 0 1 1.11-1.79l8-4a2 2 0 0 1 1.79 0z" /><path d="M2.32 6.16L12 11l9.68-4.84" /><path d="M12 22.76V11" /></>}
          {item.icon === 'key' && <><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" /></>}
          {item.icon === 'chart' && <><path d="M18 20V10" /><path d="M12 20V4" /><path d="M6 20v-6" /></>}
          {item.icon === 'alert' && <><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><path d="M12 9v4" /><path d="M12 17h.01" /></>}
          {item.icon === 'book' && <><path d="M4 19V5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v14" /><path d="M4 19h16" /><path d="M12 3v16" /></>}
        </svg>
        {item.label}
      </a>
    ))}
  </nav>

  <div class={styles.footer}>
    <UpdatePill client:only="preact" />
    <UpdateDialog client:only="preact" />
    <div class={styles.footerActions}>
      <LogoutButton client:only="preact" />
      <ThemeToggle client:only="preact" />
    </div>
  </div>
</aside>

<script>
  // a11y [WCAG 2.1.1]: arrow-key navigation for sidebar nav items (roving tabindex)
  function initSidebarKeyboard() {
    const nav = document.getElementById('sidebar-nav');
    if (!nav) return;
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('[data-nav-index]'));
    if (links.length === 0) return;

    // Restore focus to the active page link
    const active = nav.querySelector<HTMLAnchorElement>('[aria-current="page"]');
    if (active) {
      links.forEach(l => l.setAttribute('tabindex', '-1'));
      active.setAttribute('tabindex', '0');
    }

    nav.addEventListener('keydown', (e: KeyboardEvent) => {
      const target = e.target as HTMLElement;
      const idx = Number(target.getAttribute('data-nav-index'));
      if (Number.isNaN(idx)) return;

      let next = -1;
      if (e.key === 'ArrowDown') {
        next = idx < links.length - 1 ? idx + 1 : 0;
      } else if (e.key === 'ArrowUp') {
        next = idx > 0 ? idx - 1 : links.length - 1;
      } else if (e.key === 'Home') {
        next = 0;
      } else if (e.key === 'End') {
        next = links.length - 1;
      }

      if (next >= 0) {
        e.preventDefault();
        links[idx].setAttribute('tabindex', '-1');
        links[next].setAttribute('tabindex', '0');
        links[next].focus();
      }
    });
  }

  function updateActiveNav() {
    const nav = document.getElementById('sidebar-nav');
    if (!nav) return;
    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>('[data-nav-index]'));
    const path = window.location.pathname;

    // Find the CSS module class for the active state from the currently active link
    const currentActive = nav.querySelector<HTMLAnchorElement>('[aria-current="page"]');
    let activeClass = '';
    if (currentActive) {
      for (const cls of currentActive.classList) {
        if (cls.includes('navItemActive') || cls.includes('Active')) {
          activeClass = cls;
          break;
        }
      }
    }

    for (const link of links) {
      const href = link.getAttribute('href') || '';
      let isActive = false;
      if (href === '/') {
        isActive = path === '/' || path.startsWith('/apps');
      } else {
        isActive = path.startsWith(href);
      }

      if (isActive) {
        link.setAttribute('aria-current', 'page');
        if (activeClass) link.classList.add(activeClass);
      } else {
        link.removeAttribute('aria-current');
        if (activeClass) link.classList.remove(activeClass);
      }
    }
  }

  initSidebarKeyboard();
  updateActiveNav();
  document.addEventListener('astro:after-swap', () => {
    updateActiveNav();
    initSidebarKeyboard();
  });
</script>
